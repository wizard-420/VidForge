# ============================================
# YouTube Automation Studio — Environment Config
# ============================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Anthropic (Claude API) — Required
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — Required for AI voiceover mode
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Pexels — Required for stock footage
# Get your key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay — Required for background music
# Get your key at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# OpenAI (DALL-E 3) — Optional, for AI image mode
OPENAI_API_KEY=sk-...

# YouTube OAuth — Generated by setup script
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json

# App Settings
WORKSPACE_DIR=./workspace
EXPORT_DIR=./exports
LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS=1
SERVER_PORT=8000
CLEANUP_AFTER_DAYS=7
