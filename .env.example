# ============================================
# VidForge (YouTube Automation Studio) — Environment Config
# ============================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# ── Required API Keys ────────────────────────

# Groq (Llama 3.3 70B) — Required for input parsing, script generation, and refinement
# Get your key at: https://console.groq.com/
GROQ_API_KEY=

# ElevenLabs — Required for AI voiceover mode.
# NOT needed when using: Manual Recording, Google TTS, or Music-Only mode.
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Google Cloud TTS — Required for Google TTS voiceover mode (basic voices)
# Enable the API and create a key at: https://console.cloud.google.com/apis/credentials
# Works for: Standard, Wavenet, Neural2, News, Casual, Polyglot, regular Chirp HD voices.
GOOGLE_CLOUD_TTS_API_KEY=

# Google Cloud Service Account — OPTIONAL, unlocks premium TTS voice families
# (Chirp 3 HD, Studio) which Google now restricts to OAuth/service-account
# auth. Without this, the dropdown only shows basic voices.
#
# How to create one (free, takes ~2 min):
#   1. https://console.cloud.google.com/iam-admin/serviceaccounts → Create Service Account
#   2. Grant role "Cloud Text-to-Speech User" (roles/texttospeech.user)
#   3. Keys tab → Add Key → Create new key → JSON → download
#
# Then set ONE of these (JSON env var preferred for Docker):
#
# Option A — paste the entire JSON on a single line (Docker-friendly):
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...",...}
#
# Option B — point to a file inside the container:
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Pexels — Required for stock video clips
# Get your key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# ── AI Image Generation (needed for ai_images or mixed video style) ──

# Together AI (FLUX.1 Schnell) — TIER 1: primary AI image provider (paid).
# Best quality. $1 free trial credit on signup; after that requires top-up.
# Get your key at: https://api.together.xyz/
TOGETHER_API_KEY=

# Cloudflare Workers AI (FLUX.1 Schnell) — TIER 2: free fallback.
# 10,000 neurons/day on the free plan ≈ 50–100 FLUX images/day, resets daily,
# no credit card required. Used automatically when Together AI is missing,
# out of credits, or rate-limited. Falls through to Pollinations.ai if both
# are unavailable.
#
# Setup (takes ~2 min, no payment info):
#   1. Sign up / log in at https://dash.cloudflare.com/
#   2. Account ID is shown in the URL after login (the hex string between
#      "/accounts/" and the next "/"), or under "Workers & Pages" → Overview.
#   3. My Profile → API Tokens → Create Token → "Custom Token"
#      Permissions: Account → Workers AI → Read
#      Save the token (it's shown only once).
#
# Both vars are required; leaving either empty disables this tier silently.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Hugging Face — Used ONLY for AI music generation when music_mode = "ai_generated"
# (facebook/musicgen-large + stabilityai/stable-audio-open-1.0).
# Note: HF's FLUX image endpoint was removed in 2025/2026; image generation
# now uses the Together AI → Cloudflare → Pollinations chain above.
# Get your key at: https://huggingface.co/settings/tokens
HF_API_KEY=

# ── Music ─────────────────────────────────────

# Jamendo — Royalty-free background music. Used by:
#   - "auto" music mode (tone-based search)
#   - "manual" music mode (UI search picker)
#   - "ai_generated" music mode (curated fallback when HuggingFace fails,
#     plus the ambience/nature layer source for birds/rain/wind/etc.)
# Has a working default; optional to change.
# Get your client ID at: https://devportal.jamendo.com/
JAMENDO_CLIENT_ID=b6747d04

# ── YouTube Upload (Optional) ─────────────────

# OAuth credentials — generated by running: go run ./cmd/setup_auth
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json

# ── App Settings ──────────────────────────────

WORKSPACE_DIR=./workspace
EXPORT_DIR=./exports
LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS=1
SERVER_PORT=8000
CLEANUP_AFTER_DAYS=7

GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...whole JSON on one line...}
# or
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json


